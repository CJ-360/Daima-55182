#include <iostream>

int main() {
    char c;
    
    // 提示用户输入（实际提交算法题时可以去掉这行提示）
    // std::cout << "请输入一个字符: ";
    
    std::cin >> c;

    // 在 C++ 中，char 类型在进行数学运算时会自动转换为对应的 ASCII 整数值
    // 判断该值对 2 取余是否为 1
    if (c % 2 != 0) {
        std::cout << "YES" << std::endl;
    } else {
        std::cout << "NO" << std::endl;
    }

    return 0;
}
